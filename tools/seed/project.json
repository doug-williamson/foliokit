{
  "name": "seed",
  "targets": {
    "firestore": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "seed:build",
        "watch": false
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "options": {
        "main": "tools/seed/seed-firestore.ts",
        "outputPath": "dist/tools/seed",
        "tsConfig": "tools/seed/tsconfig.seed.json"
      }
    },
    "emulator": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "seed:build-emulator",
        "watch": false
      }
    },
    "build-emulator": {
      "executor": "@nx/js:tsc",
      "options": {
        "main": "tools/seed/seed-emulator.ts",
        "outputPath": "dist/tools/seed",
        "tsConfig": "tools/seed/tsconfig.seed.json"
      }
    }
  }
}

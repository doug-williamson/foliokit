{
  "name": "foliokit",
  "version": "0.3.4",
  "license": "MIT",
  "scripts": {
    "start:blog": "nx serve blog --port=4201",
    "start:docs": "nx serve docs --port=4202",
    "start:admin": "nx serve admin --port=4203",
    "build:blog": "nx build blog",
    "build:docs": "nx build docs",
    "build:admin": "nx build admin",
    "build:libs": "nx run-many --target=build --projects=cms-core,cms-ui,cms-admin-ui,cms-markdown,docs-ui",
    "build:all": "nx run-many --target=build",
    "publish:cms-core": "nx build cms-core && npm publish dist/libs/cms-core --access public",
    "publish:cms-ui": "nx build cms-ui && npm publish dist/libs/cms-ui --access public",
    "publish:cms-admin-ui": "nx build cms-admin-ui && npm publish dist/libs/cms-admin-ui --access public",
    "publish:cms-markdown": "nx build cms-markdown && npm publish dist/libs/cms-markdown --access public",
    "publish:docs-ui": "nx build docs-ui && npm publish dist/libs/docs-ui --access public",
    "publish:libs": "nx run-many --target=build --projects=cms-core,cms-ui,cms-admin-ui,cms-markdown,docs-ui && npm publish dist/libs/cms-core --access public && npm publish dist/libs/cms-ui --access public && npm publish dist/libs/cms-admin-ui --access public && npm publish dist/libs/cms-markdown --access public && npm publish dist/libs/docs-ui --access public",
    "emulator": "firebase emulators:start --only auth,firestore,storage",
    "emulator:data": "firebase emulators:start --only auth,firestore,storage --import .firebase/emulator-data --export-on-exit",
    "seed": "nx run seed:emulator"
  },
  "private": false,
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.3",
    "@angular-devkit/core": "^21.2.3",
    "@angular-devkit/schematics": "^21.2.3",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/compiler-cli": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/language-service": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-server": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@angular/ssr": "^21.2.3",
    "@eslint/js": "^9.8.0",
    "@ngx-env/builder": "^21.0.1",
    "@nx/angular": "^22.5.4",
    "@nx/devkit": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/playwright": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "~21.1.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/express": "^4.17.21",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^21.0.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "ng-packagr": "^21.2.0",
    "nx": "22.5.4",
    "postcss-url": "~10.1.3",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@angular/animations": "^21.2.4",
    "@angular/cdk": "^21.2.2",
    "@angular/material": "^21.2.2",
    "@ngrx/signals": "^21.0.1",
    "autoprefixer": "^10.4.27",
    "express": "^4.21.2",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.7.0",
    "marked": "^17.0.4",
    "ngx-markdown": "^21.1.0",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "tailwindcss": "^3.4.19"
  }
}

{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["es2020"],
    "declaration": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "outDir": "./schematics",
    "rootDir": "./src/schematics",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strictNullChecks": true,
    "target": "ES2020",
    "types": ["node"]
  },
  "include": ["src/schematics/**/*.ts"],
  "exclude": ["src/schematics/**/*.spec.ts"]
}

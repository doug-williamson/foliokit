{
  "name": "cms-core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/cms-core/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["scope:shared"],
  "implicitDependencies": ["!cms-ui"],
  "targets": {
    "build-schematics": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc -p libs/cms-core/tsconfig.schematics.json",
          "cp libs/cms-core/src/schematics/collection.json libs/cms-core/schematics/collection.json",
          "cp libs/cms-core/src/schematics/ng-add/schema.json libs/cms-core/schematics/ng-add/schema.json"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "dependsOn": ["build-schematics"],
      "options": {
        "project": "libs/cms-core/ng-package.json",
        "tsConfig": "libs/cms-core/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/cms-core/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {}
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}

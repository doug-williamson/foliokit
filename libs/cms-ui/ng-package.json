{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/libs/cms-ui",
  "lib": {
    "entryFile": "src/index.ts"
  },
  "assets": [
    {
      "input": "src/styles",
      "glob": "**/*.scss",
      "output": "styles"
    },
    {
      "input": "src/styles",
      "glob": "tokens.css",
      "output": "styles"
    },
    {
      "input": "src/styles",
      "glob": "utilities.css",
      "output": "styles"
    }
  ]
}

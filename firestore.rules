rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── Admin authorization ─────────────────────────────────────────────────
    // isAdmin() checks for a 'superadmin' custom claim set via tools/scripts/set-superadmin-claim.ts.
    // Never hardcode email addresses here — claims are set out-of-band and are not visible in source.
    // To grant superadmin: run `npx ts-node tools/scripts/set-superadmin-claim.ts <uid>`.
    // To find your UID: Firebase Console → Authentication → Users.
    // ────────────────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'superadmin';
    }

    // isTenantOwner() performs a get() on the tenant document on every write.
    // This is intentional — custom claim-based resolution is deferred until write
    // volume justifies the added Auth trigger complexity. Revisit when tenants > 100.
    function isTenantOwner(tenantId) {
      return request.auth != null
        && get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerEmail == request.auth.token.email;
    }

    // ── Root-level collections (deprecated — read-only) ───────────────────
    // All new writes go through tenants/{tenantId}/<collection>.
    // These rules exist only for backwards compatibility during migration.
    match /posts/{postId} {
      allow read: if resource.data.status == 'published';
      allow write: if false;
    }
    match /pages/{pageId} {
      allow read: if resource == null || resource.data.status == 'published';
      allow write: if false;
    }
    match /tags/{tagId} {
      allow read;
      allow write: if false;
    }
    match /site-config/{siteId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /authors/{authorId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Tenant registry ───────────────────────────────────────────────────────
    // Each tenant document stores ownerEmail, subdomain, customDomain, etc.
    // Owners can read/write their own tenant doc; platform admin can manage all.
    match /tenants/{tenantId} {
      allow read: if isAdmin() || isTenantOwner(tenantId);
      allow write: if isAdmin();

      // ── Multi-tenant subcollections ────────────────────────────────────────
      // When tenantId is provided to provideFolioKit(), data lives under
      // tenants/{tenantId}/<collection>. Write access is scoped to the tenant
      // owner (looked up from the tenant document's ownerEmail field) or the
      // platform super-admin.
      match /posts/{postId} {
        allow read: if resource.data.status == 'published' || isAdmin() || isTenantOwner(tenantId);
        allow write: if isAdmin() || isTenantOwner(tenantId);
      }
      match /pages/{pageId} {
        allow read: if resource == null || resource.data.status == 'published' || isAdmin() || isTenantOwner(tenantId);
        allow write: if isAdmin() || isTenantOwner(tenantId);
      }
      match /tags/{tagId} { allow read; allow write: if isAdmin() || isTenantOwner(tenantId); }
      match /site-config/{configId} { allow read; allow write: if isAdmin() || isTenantOwner(tenantId); }
      match /authors/{authorId} { allow read; allow write: if isAdmin() || isTenantOwner(tenantId); }
    }

    // ── Billing ───────────────────────────────────────────────────────────────
    match /billing/{tenantId} {
      // Owners can read their own billing record to display plan/status in the admin UI.
      // Writes are performed exclusively via Admin SDK (Cloud Functions) which bypasses
      // these rules. Client-side writes are never legitimate.
      allow read: if isAdmin() || isTenantOwner(tenantId);
      allow write: if false;
    }
  }
}

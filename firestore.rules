rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── Admin authorization ─────────────────────────────────────────────────
    // Replace 'YOUR_ADMIN_EMAIL' below with your actual admin email address.
    // This must match all four authorization surfaces:
    //   1. The Firebase Authentication account used to sign in with Google
    //   2. The adminEmail value passed to provideAdminKit() in app.config.ts
    //   3. The author document created by the seed script
    //   4. This file (the only surface that cannot read a runtime value)
    // See docs/security/admin-authorization.md for the full authorization model.
    // ────────────────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'dev.foliokit@gmail.com';
    }

    match /posts/{postId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }
    match /pages/{pageId} {
      allow read: if resource == null || resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }
    match /tags/{tagId} { allow read; allow write: if isAdmin(); }
    match /site-config/{siteId} { allow read; allow write: if isAdmin(); }
    match /authors/{authorId} { allow read; allow write: if isAdmin(); }

    // ── Multi-tenant subcollections ──────────────────────────────────────────
    // When siteId is provided to provideFolioKit(), data lives under
    // sites/{siteId}/<collection>. These rules mirror the root-level rules.
    match /sites/{siteId} {
      match /posts/{postId} {
        allow read: if resource.data.status == 'published' || isAdmin();
        allow write: if isAdmin();
      }
      match /pages/{pageId} {
        allow read: if resource == null || resource.data.status == 'published' || isAdmin();
        allow write: if isAdmin();
      }
      match /tags/{tagId} { allow read; allow write: if isAdmin(); }
      match /site-config/{configId} { allow read; allow write: if isAdmin(); }
      match /authors/{authorId} { allow read; allow write: if isAdmin(); }
    }
  }
}
